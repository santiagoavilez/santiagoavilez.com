---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Icon from "@components/Icon.astro";
import { FEATURED_ORDER, OTHER_WORK_ORDER } from "@lib/projectOrder";

const allProjects = await getCollection("projects");
type ProjectEntry = (typeof allProjects)[number];

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/previews/*.{jpeg,jpg,png,gif,webp}"
);

const orderedFeatured: ProjectEntry[] = [];
for (const id of FEATURED_ORDER) {
  const project = allProjects.find((p) => p.id === id && p.data.featured);
  if (project) orderedFeatured.push(project);
}

const featuredWithImages = await Promise.all(
  orderedFeatured.map(async (project) => {
    const { default: src } = await images[project.data.img]();
    return { project, src };
  })
);

const nonFeatured = allProjects.filter((p) => !p.data.featured);
const orderedGridProjects: ProjectEntry[] = [];
for (const id of OTHER_WORK_ORDER) {
  const project = nonFeatured.find((p) => p.id === id);
  if (project) orderedGridProjects.push(project);
}

const gridProjects = await Promise.all(
  orderedGridProjects.map(async (project) => {
    const imageLoader = images[project.data.img];
    if (!imageLoader) {
      throw new Error(
        `"${project.data.img}" does not exist in glob: "/src/assets/previews/*.{jpeg,jpg,png,gif,webp}"`
      );
    }
    const { default: src } = await imageLoader();
    return { project, src };
  })
);
---

<section class="flex flex-col gap-14 px-6 py-12 w-full max-w-[68rem] mx-auto">

  <!-- Section header -->
  <div class="flex justify-between items-end">
    <div>
      <h2 class="text-4xl font-bold text-white">Projects</h2>
      <p class="text-gray-500 mt-1 text-sm">Things I've built end-to-end</p>
    </div>
    <a
      href="/projects/"
      class="hidden md:flex items-center gap-1.5 text-sm font-medium text-cerulean-400 hover:underline"
    >
      View all <Icon icon="arrow-right" size="1em" />
    </a>
  </div>

  <!-- Featured Projects -->
  <div class="flex flex-col gap-4">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Featured</p>
    <div class="flex flex-col gap-8">
      {featuredWithImages.map(({ project, src }) => (
        <article class="flex flex-col md:flex-row rounded-2xl overflow-hidden border border-gray-800 bg-gray-900/30 group hover:border-cerulean-400/40 transition-all duration-300 hover:shadow-lg hover:shadow-cerulean-400/5">

          <!-- Image -->
          <a href={`/projects/${project.id}`} class="md:w-[42%] shrink-0 block overflow-hidden">
            <Image
              src={src}
              alt={project.data.img_alt || project.data.title}
              width={project.data.img_w}
              height={project.data.img_h}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 " 
              format="webp"
            />
          </a>

          <!-- Content -->
          <div class="flex flex-col justify-center gap-5 p-7 md:p-10 group-hover:text-cerulean-400 transition-colors duration-200">

            {project.data.role && (
              <span class="text-xs font-semibold text-cerulean-400 uppercase tracking-widest">
                {project.data.role}
              </span>
            )}

            <a href={`/projects/${project.id}`} class="group">
              <h3 class="text-2xl font-bold text-white group-hover:text-cerulean-400 transition-colors duration-200">
                {project.data.title}
              </h3>
            </a>

            <p class="text-gray-400 text-sm leading-relaxed">
              {project.data.description}
            </p>

            {project.data.highlights && project.data.highlights.length > 0 && (
              <ul class="flex flex-col gap-2.5">
                {project.data.highlights.map((h) => (
                  <li class="flex gap-2.5 text-sm text-gray-400 leading-snug">
                    <span class="text-cerulean-400 shrink-0 mt-0.5 text-xs">▸</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            )}

            {project.data.tools && project.data.tools.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {project.data.tools.map((tool) => (
                  <span class="text-xs px-3 py-1 rounded-full border border-cerulean-400/30 text-cerulean-400 bg-cerulean-400/5">
                    {tool.name}
                  </span>
                ))}
              </div>
            )}

            <div class="flex gap-5 flex-wrap items-center pt-1">
              {project.data.live && (
                <a
                  href={project.data.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-semibold text-cerulean-400 hover:underline"
                >
                  Live Preview ↗
                </a>
              )}
              {project.data.git ? (
                <a
                  href={project.data.git}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
                >
                  GitHub ↗
                </a>
              ) : (
                <span class="text-sm text-gray-600">🔒 Private codebase</span>
              )}
            </div>

          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Other Work -->
  <div class="flex flex-col gap-4">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Other Work</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-6">
      {gridProjects.map(({ project, src }, index) => (
        <article
          class="group rounded-2xl overflow-hidden border border-gray-800 bg-gray-900/30 hover:border-cerulean-400/40 transition-all duration-300 hover:shadow-lg hover:shadow-cerulean-400/5"
          data-aos="fade-up"
          data-aos-delay={String(index * 100)}
        >
          <a href={`/projects/${project.id}`} class="block">
            <!-- Image: 16:9 aspect ratio -->
            <div class="overflow-hidden">
              <Image
                src={src}
                alt={project.data.img_alt || project.data.title}
                width={project.data.img_w}
                height={project.data.img_h}
                class="w-full aspect-video object-cover transition-transform duration-500 group-hover:scale-105"
                format="webp"
              />
            </div>
            <!-- Content -->
            <div class="p-5 flex flex-col gap-3">
              <h3 class="text-lg font-semibold text-white group-hover:text-cerulean-400 transition-colors duration-200">
                {project.data.title}
              </h3>
              <p class="text-sm text-gray-400 line-clamp-2 leading-relaxed">
                {project.data.description}
              </p>
              <!-- Stack badges (max 5) -->
              {project.data.tools && project.data.tools.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {project.data.tools.slice(0, 5).map((tool) => (
                    <span class="text-xs px-2.5 py-0.5 rounded-full border border-cerulean-400/30 text-cerulean-400 bg-cerulean-400/5">
                      {tool.name}
                    </span>
                  ))}
                </div>
              )}
              <!-- Links -->
              <div class="flex gap-4 items-center pt-1">
                {project.data.live && (
                  <span class="text-xs font-medium text-cerulean-400">
                    Live ↗
                  </span>
                )}
                {project.data.git && (
                  <span class="text-xs text-gray-500">
                    GitHub ↗
                  </span>
                )}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>

  <!-- Mobile: View all -->
  <div class="md:hidden">
    <a
      href="/projects/"
      class="flex items-center gap-1.5 text-sm font-medium text-cerulean-400 hover:underline"
    >
      View all projects <Icon icon="arrow-right" size="1em" />
    </a>
  </div>

</section>
