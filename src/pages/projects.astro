---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import Hero from "../components/Hero.astro";
import Grid from "../components/Grid.astro";

const allProjects = (await getCollection("projects")).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// Fulbbo will be added in Task 5b — it will appear first in Featured Projects via featured: true + publishDate
const featured = allProjects.filter((p) => p.data.featured);
const otherWork = allProjects.filter((p) => !p.data.featured);
---

<BaseLayout
	title="My Work | Santiago Avilez"
	description="A look at my most recent projects — from full-stack engineering work to client and optimization projects."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-16">
			<Hero
				title="My Work"
				tagline="A look at my most recent projects — end-to-end engineering work and client projects."
				align="start"
			/>

			<!-- Featured Projects -->
			<section class="stack gap-8">
				<header class="stack gap-2">
					<h2 class="text-2xl font-semibold">Featured Projects</h2>
					<p class="text-gray-400">End-to-end engineering work</p>
				</header>
				<Grid variant="offset">
					{
						featured.map((project, index) => (
							<li class="overflow-hidden">
								<PortfolioPreview
									index={index % 2}
									project={project}
								/>
							</li>
						))
					}
				</Grid>
			</section>

			<!-- Other Work -->
			<section class="stack gap-8">
				<header class="stack gap-2">
					<h2 class="text-2xl font-semibold">Other Work</h2>
					<p class="text-gray-400">Client and optimization work</p>
				</header>
				<Grid variant="offset">
					{
						otherWork.map((project, index) => (
							<li class="overflow-hidden">
								<PortfolioPreview
									index={index % 2}
									project={project}
								/>
							</li>
						))
					}
				</Grid>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
