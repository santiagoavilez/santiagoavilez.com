---
import Brands from "./Brands.astro";
import portrait from "../../../assets/hero/profile_picture.jpg";
import { Image } from "astro:assets";
---

<div
  class="w-full flex flex-col items-center justify-center gap-28 m-auto md:p-10 min-h-[calc(75svh)] h-full"
>
  <div
    class="stack container p-5 justify-center md:justify-start gap-6 items-center text-center h-full"
  >
    <div
      class="flex flex-col md:flex-row w-full justify-around gap-6 items-center"
    >
      <div class="flex flex-col text-center md:text-left items-start gap-4">
        <h1 class="text-4xl md:text-7xl leading-tight font-bold text-cerulean-400">
          Full Stack Developer
        </h1>

        <p class="text-xl md:text-2xl font-semibold text-cerulean-400">
          React · Next.js · TypeScript · Node.js · NestJS · PostgreSQL
        </p>

        <p class="text-base md:text-lg max-w-screen-md text-gray-300 leading-relaxed">
          I design and build scalable web products <span class="text-cerulean-400 font-semibold">end-to-end</span> — from clean,
          performant frontends to well-architected backends. <span class="text-cerulean-400 font-semibold">5+ years</span> shipping
          real features in production.<br />
          Currently open to full-time remote roles at product companies in the US.
        </p>

        <div class="flex flex-wrap gap-3 justify-center md:justify-start mt-2">
          <a href="/resume.pdf" download>
            <button
              class="font-bold text-xl bg-gradient-to-r from-cerulean-600 to-cyan-400 py-3 px-6 rounded-md text-white"
            >
              Download Resume
            </button>
          </a>
          <a
            href="https://linkedin.com/in/santiago-avilez-ariza/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <button
              class="font-bold text-xl border border-cerulean-400 text-cerulean-400 hover:bg-cerulean-400 hover:text-white transition-colors py-3 px-6 rounded-md"
            >
              LinkedIn ↗
            </button>
          </a>
        </div>
      </div>
      <div class="w-72 hidden md:block md:w-[560px] md:order-2">
        <Image
          src={portrait}
          width={500}
          alt="Santiago Avilez — Full Stack Developer"
          class="w-full rounded-full"
        />
      </div>
    </div>
  </div>
  <div data-aos="fade" data-aos-duration="800" data-aos-easing="ease-in-sine">
    <div class="h-20">
      <Brands direction="backward" />
    </div>
    <div class="h-20">
      <Brands direction="forward" />
    </div>
  </div>
</div>
