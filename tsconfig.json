{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": "./",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
    "@components/*": [
      "src/components/*"
    ],
    "public/*": [
      "public/*"
    ],
    "@assets/*": [
        "src/assets/*"
      ],
    "@lib/*": [
        "./src/lib/*"
    ]
    }
  }
}
