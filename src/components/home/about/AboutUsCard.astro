---
import { Image } from "astro:assets";
import { CardDescription, CardTitle } from "@components/ui/card";
import { ArrowUpRight } from "lucide-react";

const yearsOfExperience = Math.floor((Date.now() - new Date(2020, 11, 1).getTime()) / (365.25 * 24 * 60 * 60 * 1000));

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  odd?: boolean;
}

const { odd, title, description, image } = Astro.props;
---

<div
  data-aos={odd ? "fade-left" : "fade-right"}
  data-aos-duration="200"
  data-aos-easing="ease-in-sine"
  data-aos-once="false"
  class="flex flex-col md:flex-row h-full w-full items-center md:items-start justify-center gap-3 md:gap-8"
>
  <div
    class={`flex gap-3 w-full max-w-xl justify-between  ${odd ? "md:-translate-y-52" : ""}`}
  >
    <div
      data-aos={odd ? "fade-down-left" : "fade-up-right"}
      data-aos-duration="600"
      data-aos-easing="ease-in"
      data-aos-once="false"
      class={`border-2 border-gray-50/85 w-fit h-auto  rounded-full p-2 aspect-square place-self-center ${odd ? "order-4 md:place-self-end md:mb-4" : " md:place-self-start md:mt-4"}`}
    >
      <ArrowUpRight className={`"w-8 md:w-12 md:h-12 ${odd && "rotate-180"}`} />
    </div>
    <div
      class={`relative w-full aspect-square border-2 border-gray-50/85 g-transparent rounded-lg ${odd ? "ml-4" : "mr-4"}`}
    >
      <Image
        class={`absolute w-full rounded-lg top-4  ${odd ? "right-4" : "left-4"}`}
        src={image}
        alt="about us"
        width={500}
        height={500}
      />
    </div>
  </div>
  <div
    class={`pt-4 max-w-2xl text-left ${odd && "md:order-first md:text-right "}`}
  >
    <!-- <CardTitle className="text-3xl"> {title} </CardTitle> -->
    <CardDescription className="pt-2 text-xl">
      I'm a <span class="text-cerulean-400 font-medium">Full Stack Developer</span> based in Argentina, with <span class="text-cerulean-400 font-medium">{yearsOfExperience}+ years</span> of experience
      building web products that actually scale.
    </CardDescription>
    <CardDescription className="pt-6 text-xl">
      I work across the full stack — building React and Next.js frontends, designing
      REST and tRPC APIs with Node.js and NestJS, and managing PostgreSQL databases
      with a focus on data integrity and performance. On the infrastructure side, I'm
      comfortable with Docker, CI/CD pipelines on GitHub Actions, and deployments on
      AWS and Vercel.
    </CardDescription>
    <CardDescription className="pt-6 text-xl">
      I care a lot about how code is structured. I gravitate toward <span class="text-cerulean-400 font-medium">Clean Architecture / Vertical Slice Architecture</span>
      and <span class="text-cerulean-400 font-medium">Domain-Driven Design</span> not because they're fashionable, but because they make
      systems easier to maintain and evolve over time — especially in startup
      environments where requirements change fast.
    </CardDescription>
    <CardDescription className="pt-6 text-xl">
      I've worked on SaaS platforms, marketplace apps, and MVPs across different
      industries. I'm used to working asynchronously, communicating in English, and
      owning features from spec to deployment.
    </CardDescription>
    <CardDescription className="pt-6 text-xl">
      Looking for a remote, full-time role where I can contribute to a product team
      and grow alongside it.
    </CardDescription>
    <CardDescription className="pt-6 text-xl">
      Outside of work, I stay disciplined through boxing and weightlifting, and I spend most weekends building Fulbbo or exploring side projects. I believe consistency compounds — in code and in life.
    </CardDescription>

    <div class="pt-8 flex flex-wrap gap-4">
      <a
        href="/resume.pdf"
        download="Santiago_Avilez_Full_Stack_Developer.pdf"
        class="inline-flex items-center gap-2 rounded-md bg-cerulean-400 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-cerulean-500 transition-colors"
      >
        Download Resume
      </a>
      <a
        href="https://linkedin.com/in/santiago-avilez-ariza/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md border border-cerulean-400 px-5 py-2.5 text-sm font-semibold text-cerulean-400 hover:bg-cerulean-400/10 transition-colors"
      >
        Let's connect on LinkedIn ↗
      </a>
    </div>
  </div>
</div>
