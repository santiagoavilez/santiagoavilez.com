---
const experience = [
  {
    role: "Full Stack Developer",
    company: "Zoada Dev Studio",
    period: "Feb 2025 – Present",
    description:
      "Architected and shipped client-facing digital platforms (React + NestJS + PostgreSQL) serving 50,000+ users, owning end-to-end delivery from data modeling to production deployment.",
    url: null,
    stack: ['TypeScript' , "React", "NestJS", "PostgreSQL", "Docker" ,"Jest" ],
  },
  {
    role: "Full Stack Developer",
    company: "Eximo",
    period: "Dec 2020 – Jan 2025",
    description:
      "Built full-stack applications for enterprise clients with 5,000+ active users, owning end-to-end delivery. Reduced page load times by 40% and modernized legacy services using Clean Architecture and DDD, improving modularity and reducing onboarding time for new engineers.",
    url: null,
    stack: ['TypeScript', "React", "NestJS", "PostgreSQL" , "Tailwind CSS" ,'CI/CD'],
  },
  {
    role: "Co-Founder & Lead Engineer",
    company: "Fulbbo",
    period: "2025 – Present",
    description:
      "Designed and built a full-stack soccer social platform — booking, payments, real-time chat, and geographic search. Reduced Google Places API costs by ~90% with a custom PostgreSQL cache system.",
    url: "https://fulbbo.vercel.app",
    stack: ["TypeScript" ,"React", "Next.js", "Node.js", "PostgreSQL", "Vercel" , "Vitest"],
  },
];
---

<section class="w-full max-w-[68rem] mx-auto px-6 py-8">
  <p class="text-xs font-semibold uppercase tracking-widest text-cerulean-400/60 mb-6" data-aos="fade-right">
    Experience
  </p>
  <div class="timeline-wrapper relative flex flex-col gap-0 ml-2">
    {/* Background track */}
    <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-cerulean-400/30"></div>
    {/* Scroll-filled track */}
    <div class="timeline-fill absolute left-0 top-0 w-[2px] bg-cerulean-400 origin-top" style="transform: scaleY(0);"></div>

    {
      experience.map((entry) => (
        <div class="timeline-entry group relative pl-6 pb-8 last:pb-0 rounded-r-lg transition-all duration-300 hover:bg-cerulean-400/[0.04]">
          {/* Dot marker */}
          <span class="absolute -left-[7px] top-[4px] w-3 h-3 rounded-full bg-cerulean-400 border-2 border-cerulean-400/40 transition-all duration-300 group-hover:scale-125 group-hover:shadow-[0_0_10px_rgba(0,164,219,0.4)]" />

          {/* Role */}
          <p class="font-semibold text-sm text-white leading-snug transition-colors duration-200 group-hover:text-cerulean-400">
            {entry.role}
          </p>

          {/* Company · Period */}
          <p class="text-xs text-gray-400 mt-0.5 tracking-wide">
            {entry.company} · {entry.period}
          </p>

          {/* Description */}
          <p class="text-xs text-gray-400 mt-1 leading-relaxed max-w-xl">
            {entry.description}
          </p>

          {/* Stack badges */}
          <div class="flex flex-wrap gap-2">
            {entry.stack.map((stack) => (
              <span class="text-xs font-medium px-3 py-1 rounded-full border border-cerulean-400/30 text-cerulean-400 bg-cerulean-400/5 hover:bg-cerulean-400/20 hover:border-cerulean-400/60 hover:scale-105 hover:shadow-[0_0_12px_rgba(0,164,219,0.15)] transition-all duration-200 cursor-default mt-2">
                {stack}
              </span>
            ))}
          </div>

          {/* URL — only if not null */}
          {entry.url !== null && (
            <a
              href={entry.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-1.5 text-[11px] text-cerulean-400 hover:text-cerulean-300 transition-colors"
            >
              {new URL(entry.url).hostname} ↗
            </a>
          )}
        </div>
      ))
    }
  </div>
</section>

<script>
  function initTimelineFill() {
    document.querySelectorAll('.timeline-wrapper').forEach((wrapper) => {
      const fill = wrapper.querySelector('.timeline-fill') as HTMLElement;
      if (!fill) return;

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const timelineEntries = Array.from(wrapper.querySelectorAll('.timeline-entry')) as HTMLElement[];
      const revealed = new Set<HTMLElement>();

      if (!reducedMotion) {
        timelineEntries.forEach(entry => {
          entry.style.opacity = '0';
          entry.style.transform = 'translateY(12px)';
          entry.style.transition = 'opacity 400ms ease-out, transform 400ms ease-out';
        });
      }

      const observer = new IntersectionObserver(() => {
        requestAnimationFrame(() => updateFill(wrapper as HTMLElement, fill, timelineEntries, revealed, reducedMotion));
      }, { threshold: 0 });

      observer.observe(wrapper);

      const onScroll = () => requestAnimationFrame(() => updateFill(wrapper as HTMLElement, fill, timelineEntries, revealed, reducedMotion));
      window.addEventListener('scroll', onScroll, { passive: true });
    });
  }

  function updateFill(wrapper: HTMLElement, fill: HTMLElement, timelineEntries: HTMLElement[], revealed: Set<HTMLElement>, reducedMotion: boolean) {
    const rect = wrapper.getBoundingClientRect();
    const viewportH = window.innerHeight;

    const startTrigger = viewportH * 0.8;
    const scrolled = startTrigger - rect.top;
    const totalHeight = rect.height;

    if (scrolled <= 0) {
      fill.style.transform = 'scaleY(0)';
      return;
    }

    const progress = Math.min(scrolled / totalHeight, 1);
    fill.style.transform = `scaleY(${progress})`;

    const wrapperHeight = wrapper.getBoundingClientRect().height;
    timelineEntries.forEach(entry => {
      if (revealed.has(entry)) return;
      const threshold = (entry.offsetTop / wrapperHeight) - 0.05;
      if (progress >= threshold) {
        revealed.add(entry);
        entry.style.opacity = '1';
        entry.style.transform = 'none';
      }
    });
  }

  document.addEventListener('astro:page-load', initTimelineFill);
  initTimelineFill();
</script>
